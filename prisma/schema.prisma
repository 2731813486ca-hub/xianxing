generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  bio       String   @default("")
  avatarUrl String   @default("")
  wechatName    String @default("")
  wechatAccount String @default("")
  role           String  @default("user")
  isForestAdmin  Boolean @default(false)
  memberStatus   String  @default("unfilled")
  ip        String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  works     Work[]
  likes     Like[]
  favorites Favorite[]
  comments  Comment[]

  @@index([ip, createdAt])
}

model Work {
  id              String   @id @default(cuid())
  title           String
  description     String   @default("")
  productUrl      String   @default("")
  category        String   @default("")
  isVisible       Boolean  @default(true)
  isPinned        Boolean  @default(false)
  popularityScore Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  authorId  String
  author    User      @relation(fields: [authorId], references: [id])
  images    WorkImage[]
  likes     Like[]
  favorites Favorite[]
  comments  Comment[]
}

model WorkImage {
  id        String   @id @default(cuid())
  url       String
  alt       String   @default("")
  sortOrder Int      @default(0)

  workId String
  work   Work   @relation(fields: [workId], references: [id], onDelete: Cascade)
}

model Like {
  createdAt DateTime @default(now())

  userId String
  user   User @relation(fields: [userId], references: [id])
  workId String
  work   Work @relation(fields: [workId], references: [id], onDelete: Cascade)

  @@unique([userId, workId])
}

model Favorite {
  createdAt DateTime @default(now())

  userId String
  user   User @relation(fields: [userId], references: [id])
  workId String
  work   Work @relation(fields: [workId], references: [id], onDelete: Cascade)

  @@unique([userId, workId])
}

model Comment {
  id        String   @id @default(cuid())
  content   String
  isReview  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String
  user   User @relation(fields: [userId], references: [id])
  workId String
  work   Work @relation(fields: [workId], references: [id], onDelete: Cascade)

  @@index([workId, createdAt])
}

model Archive {
  id               String   @id @default(cuid())
  title            String
  summary          String   @default("")
  abstract         String   @default("")
  points           String[] @default([])
  keywords         String[] @default([])
  sourceName       String   @default("")
  sourceUrl        String   @default("")
  sourceDate       String   @default("")
  attachmentFileId String   @default("")
  attachmentUrl    String   @default("")
  attachmentType   String   @default("")
  originalFileName String   @default("")
  rawText          String   @default("")
  status           String   @default("published")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([status, createdAt])
  @@index([createdAt])
}
